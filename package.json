{
  "name": "template-typescript-cli",
  "version": "0.0.0",
  "description": "A minimal TypeScript CLI template with Commander.js, Biome, Vitest, and npm OIDC publishing",
  "type": "module",
  "bin": {
    "template-typescript-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "check": "biome check src/ tests/",
    "format": "biome format --write src/ tests/",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "typescript",
    "cli",
    "template",
    "nodejs",
    "commander-js"
  ],
  "author": {
    "name": "Calvin",
    "url": "https://github.com/calvindotsg"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calvindotsg/template-typescript-cli.git"
  },
  "homepage": "https://github.com/calvindotsg/template-typescript-cli#readme",
  "bugs": {
    "url": "https://github.com/calvindotsg/template-typescript-cli/issues"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
